# Private key for the deployer/admin account. Keep the 0x prefix.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# RPC endpoints used by Foundry for each testnet.
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.example
AVALANCHE_FUJI_RPC_URL=https://avalanche-fuji-rpc.example

# Token constructor inputs. Fill before running DeployToken on each chain.
TOKEN_NAME="SecureVal Token"
TOKEN_SYMBOL=SVAL
TOKEN_DECIMALS=18
# Use 0 for unlimited supply, or a wei-denominated token amount for a cap.
TOKEN_MAX_SUPPLY=0
# Optional initial mint to the deployer during token deployment.
TOKEN_PREMINT=0

# Fill after DeployToken on each chain. Use the generic TOKEN_ADDRESS when a
# script runs on one chain, or the chain-specific variables for README commands.
TOKEN_ADDRESS=
ETHEREUM_SEPOLIA_TOKEN_ADDRESS=
AVALANCHE_FUJI_TOKEN_ADDRESS=

# Fill after DeployPool on each chain. POOL_ADDRESS is used by SetPool;
# LOCAL_POOL_ADDRESS is used by ConfigurePool on the chain being configured.
POOL_ADDRESS=
LOCAL_POOL_ADDRESS=
ETHEREUM_SEPOLIA_POOL_ADDRESS=
AVALANCHE_FUJI_POOL_ADDRESS=

# Fill before ConfigurePool. These are the remote chain's deployed token/pool.
REMOTE_TOKEN_ADDRESS=
REMOTE_POOL_ADDRESS=

# Optional override for ConfigurePool or TransferTokens. If omitted, scripts use
# the opposite chain selector for Sepolia <-> Fuji.
REMOTE_CHAIN_SELECTOR=
DESTINATION_CHAIN_SELECTOR=

# Fill before Mint and TransferTokens. RECEIVER is the token recipient on the
# active chain for Mint and the destination-chain recipient for TransferTokens.
RECEIVER=
AMOUNT=1000000000000000000

# Native fee token is address(0). Set to a LINK address if you want LINK fees
# and have funded the sender with testnet LINK.
FEE_TOKEN=0x0000000000000000000000000000000000000000

# Optional rate limiter settings used by ConfigurePool. Disabled limiters must
# keep capacity and rate at 0.
OUTBOUND_RATE_LIMIT_ENABLED=false
OUTBOUND_RATE_LIMIT_CAPACITY=0
OUTBOUND_RATE_LIMIT_RATE=0
INBOUND_RATE_LIMIT_ENABLED=false
INBOUND_RATE_LIMIT_CAPACITY=0
INBOUND_RATE_LIMIT_RATE=0
